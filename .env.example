# EzDocs Backend — copy to backend/.env and adjust

# Ollama model for code explanations and narrator (default: qwen2.5-coder:3b)
EZDOCS_MODEL=qwen2.5-coder:3b

# Max concurrent Ollama requests for batch inference (default: 4)
EZDOCS_BATCH_CONCURRENCY=4

# Directory for cloned/uploaded codebases (default: ./ingested_codebases)
# EZDOCS_INGEST_DIR=./ingested_codebases
