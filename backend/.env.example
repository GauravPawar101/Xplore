# EzDocs Backend — copy to backend/.env and adjust
# Full setup: see repo root GETTING_STARTED.md (what to get, where to put it)

# ─── LLM: Hugging Face Inference (preferred) or Ollama ─────────────────────
# If HUGGINGFACE_HUB_TOKEN is set, explanations use HF Inference API (no Docker/Ollama).
# Get token: https://huggingface.co/settings/tokens (enable "Inference").
# HUGGINGFACE_HUB_TOKEN=hf_...
# EZDOCS_HF_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# EZDOCS_HF_MODEL=Qwen/Qwen2.5-72B-Instruct
# EZDOCS_HF_MAX_TOKENS=512
# EZDOCS_HF_BATCH_WORKERS=8

EZDOCS_MODEL=qwen2.5-coder:3b
EZDOCS_BATCH_CONCURRENCY=4
# OLLAMA_HOST=http://127.0.0.1:11434
# EZDOCS_INGEST_DIR=./ingested_codebases

# Postgres — create database "ezdocs" in pgAdmin/psql; change user/pass if needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ezdocs

# MongoDB — default for local server (same as Compass)
MONGODB_URI=mongodb://localhost:27017

# Milvus — run Milvus first (e.g. Docker: see GETTING_STARTED.md)
MILVUS_URI=http://localhost:19530

# Optional: API keys (summaries / code gen when user doesn't send key)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Clerk auth — required for sign-in; get JWKS URL from Clerk Dashboard
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Option C — Job queue (Upstash Redis). If set, analysis runs via queue + worker; frontend polls /jobs/:id/status.
# Get URL and token from https://console.upstash.com (create a Redis database, free tier).
UPSTASH_REDIS_REST_URL="https://intent-cockatoo-14011.upstash.io"
UPSTASH_REDIS_REST_TOKEN="ATa7AAIncDIwZWE1MzBkYmEzYzI0Y2MwODAyYmI3OGVlNTExYjgzMHAyMTQwMTE"
